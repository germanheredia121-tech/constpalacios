---
interface Props {
  heroPhoto?: string;
}
const { heroPhoto } = Astro.props;
---

<div id="loader" class="fixed inset-0 z-[9999] bg-stone-50 flex flex-col items-center justify-center transition-opacity duration-500 ease-out loader-elaborate" aria-hidden="true">
  <div class="loader-logo mb-8">
    <p class="font-display text-3xl sm:text-4xl font-semibold text-sage tracking-[0.25em] opacity-0 loader-text">
      Constanza Palacios
    </p>
  </div>
  <div class="w-32 sm:w-40 h-0.5 bg-stone-200 rounded-full overflow-hidden">
    <div 
      class="h-full bg-gradient-to-r from-sage to-sage/80 rounded-full transition-all duration-1000 ease-[cubic-bezier(0.4,0,0.2,1)] loader-bar"
      style="width: 0%"
      id="loader-bar"
    ></div>
  </div>
  <p class="text-stone-400 text-xs uppercase tracking-[0.3em] mt-6 opacity-0 loader-subtitle">Modelo · Pasarela</p>
</div>

<style>
  .loader-text { animation: loader-fade-in 0.8s ease-out 0.2s forwards; }
  .loader-subtitle { animation: loader-fade-in 0.6s ease-out 0.6s forwards; }
  @keyframes loader-fade-in { to { opacity: 1; } }
</style>
<script define:vars={{ heroPhoto }}>
  document.addEventListener('DOMContentLoaded', () => {
    const loader = document.getElementById('loader');
    const bar = document.getElementById('loader-bar');
    if (!loader || !bar) return;

    const minTime = 1200;
    const start = Date.now();

    const finish = () => {
      const elapsed = Date.now() - start;
      const remaining = Math.max(0, minTime - elapsed);
      setTimeout(() => {
        loader.style.opacity = '0';
        loader.style.pointerEvents = 'none';
        window.dispatchEvent(new CustomEvent('loader-complete'));
        setTimeout(() => loader.remove(), 500);
      }, remaining);
    };

    // Animar barra
    requestAnimationFrame(() => {
      bar.style.width = '100%';
    });

    if (heroPhoto) {
      const img = new Image();
      img.onload = finish;
      img.onerror = finish;
      img.src = heroPhoto;
    } else {
      finish();
    }
  });
</script>

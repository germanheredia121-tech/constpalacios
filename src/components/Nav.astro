---
import { siteConfig } from "../data/portfolio";
---

<nav id="nav" class="fixed top-0 left-0 right-0 z-50 border-b border-transparent transition-all duration-500 -translate-y-full" data-visible="false">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 h-16 sm:h-20 flex items-center justify-between">
    <a href="#" class="flex items-center gap-2 group">
      <span class="font-display text-xl sm:text-2xl font-semibold text-stone-900 group-hover:text-sage transition-colors">Constanza</span>
    </a>
    <div class="hidden md:flex items-center gap-8">
      <a href="#trabajos" class="nav-link text-sm font-medium text-stone-600 hover:text-sage transition-colors">Mis Trabajos</a>
      <a href="#sobre-mi" class="nav-link text-sm font-medium text-stone-600 hover:text-sage transition-colors">Sobre Mí</a>
      <a href="#caracteristicas" class="nav-link text-sm font-medium text-stone-600 hover:text-sage transition-colors">Características</a>
      <a href="#contacto" class="nav-link text-sm font-medium text-stone-600 hover:text-sage transition-colors">Contacto</a>
    </div>
    <div class="flex items-center gap-3 sm:gap-4">
      <a href={`https://instagram.com/${siteConfig.instagram}`} target="_blank" rel="noopener" class="hidden sm:inline-flex items-center gap-2 text-stone-500 hover:text-sage transition-colors text-sm">
        <i class="ph ph-instagram-logo ph-icon text-lg"></i>
        @{siteConfig.instagram}
      </a>
      <a href={`https://instagram.com/${siteConfig.instagram}`} target="_blank" rel="noopener" class="md:hidden w-10 h-10 rounded-full border-2 border-stone-200 flex items-center justify-center text-stone-600 hover:border-sage hover:text-sage transition-all duration-300" aria-label="Instagram">
        <i class="ph ph-instagram-logo ph-icon text-xl"></i>
      </a>
      <a href="#contacto" class="bg-sage hover:bg-sage-dark text-white px-5 py-2.5 rounded-full text-sm font-medium transition-all duration-300 hover:scale-[1.02] active:scale-[0.98]">
        Contáctame
      </a>
      <button id="menu-btn" class="md:hidden w-10 h-10 flex flex-col items-center justify-center gap-1.5" aria-label="Menú">
        <span class="w-5 h-0.5 bg-stone-700 transition-all" id="line1"></span>
        <span class="w-5 h-0.5 bg-stone-700 transition-all" id="line2"></span>
        <span class="w-5 h-0.5 bg-stone-700 transition-all" id="line3"></span>
      </button>
    </div>
  </div>
</nav>

<!-- Mobile menu (animado) -->
<div id="mobile-menu" class="fixed inset-0 z-40 bg-stone-50 flex flex-col items-center justify-center gap-8 opacity-0 invisible transition-all duration-500 ease-out md:hidden mobile-menu-panel">
  <a href="#trabajos" class="text-2xl font-medium text-stone-700 hover:text-sage transition-colors">Mis Trabajos</a>
  <a href="#sobre-mi" class="text-2xl font-medium text-stone-700 hover:text-sage transition-colors">Sobre Mí</a>
  <a href="#caracteristicas" class="text-2xl font-medium text-stone-700 hover:text-sage transition-colors">Características</a>
  <a href="#contacto" class="text-2xl font-medium text-stone-700 hover:text-sage transition-colors">Contacto</a>
  <a href={`https://instagram.com/${siteConfig.instagram}`} target="_blank" rel="noopener" class="text-sage font-semibold">@{siteConfig.instagram}</a>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const nav = document.getElementById('nav');
    const menuBtn = document.getElementById('menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const links = mobileMenu?.querySelectorAll('a') || [];

    // Show nav after load
    const showNav = () => {
      nav?.classList.remove('-translate-y-full');
      nav?.setAttribute('data-visible', 'true');
    };
    window.addEventListener('loader-complete', showNav, { once: true });
    setTimeout(showNav, 1500);

    // Nav: transparente arriba, fondo sólido al hacer scroll
    const updateNav = () => {
      if (window.scrollY > 50) nav?.classList.add('nav-scrolled');
      else nav?.classList.remove('nav-scrolled');
    };
    window.addEventListener('scroll', updateNav, { passive: true });
    updateNav();

    // Mobile menu toggle
    menuBtn?.addEventListener('click', () => {
      mobileMenu?.classList.toggle('opacity-0');
      mobileMenu?.classList.toggle('invisible');
      document.body.style.overflow = mobileMenu?.classList.contains('invisible') ? '' : 'hidden';

      const line1 = document.getElementById('line1');
      const line2 = document.getElementById('line2');
      const line3 = document.getElementById('line3');
      if (mobileMenu?.classList.contains('invisible')) {
        line1?.style.setProperty('transform', '');
        line2?.style.setProperty('opacity', '');
        line3?.style.setProperty('transform', '');
      } else {
        line1?.style.setProperty('transform', 'rotate(45deg) translate(4px, 4px)');
        line2?.style.setProperty('opacity', '0');
        line3?.style.setProperty('transform', 'rotate(-45deg) translate(4px, -4px)');
      }
    });

    links.forEach(link => {
      link.addEventListener('click', () => {
        mobileMenu?.classList.add('opacity-0', 'invisible');
        document.body.style.overflow = '';
        const line1 = document.getElementById('line1');
        const line2 = document.getElementById('line2');
        const line3 = document.getElementById('line3');
        line1?.style.setProperty('transform', '');
        line2?.style.setProperty('opacity', '');
        line3?.style.setProperty('transform', '');
      });
    });
  });
</script>
